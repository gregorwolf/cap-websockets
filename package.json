{
  "name": "cap-websockets",
  "version": "1.0.0",
  "description": "CAP WebSockets Demo",
  "repository": "",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": "^22"
  },
  "dependencies": {
    "@cap-js-community/websocket": "^1.10.5",
    "@sap/cds": "^9",
    "@sap/xsenv": "^6",
    "@sap/xssec": "^4",
    "cron": "^4",
    "express": "^4.22.2",
    "node-os-utils": "^2",
    "passport": "^0.7.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4.0",
    "cds-launchpad-plugin": "^2"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "start:hybrid": "cds watch --profile hybrid",
    "start:hybrid:approuter": "cds bind --exec -- npm run start-local --prefix approuter",
    "cs:uaa": "cf create-service xsuaa application cap-websockets-uaa -c xs-security.json",
    "bind:uaa": "cds bind auth --to cap-websockets-uaa",
    "undeploy": "cf undeploy cap-websockets --delete-service-keys --delete-services --delete-service-brokers",
    "watch-usagedata": "cds watch --open usagedata/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-systemstatus": "cds watch --open systemstatus/webapp/index.html?sap-ui-xx-viewCache=false"
  },
  "cds": {
    "requires": {
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      }
    }
  },
  "sapux": [
    "app/shellplugin",
    "app/test",
    "app/usagedata",
    "app/systemstatus"
  ],
  "eslintConfig": {
    "extends": "eslint:recommended",
    "env": {
      "es2020": true,
      "node": true,
      "jest": true,
      "mocha": true
    },
    "globals": {
      "SELECT": true,
      "INSERT": true,
      "UPDATE": true,
      "DELETE": true,
      "CREATE": true,
      "DROP": true,
      "CDL": true,
      "CQL": true,
      "CXL": true,
      "cds": true
    },
    "rules": {
      "no-console": "off",
      "require-atomic-updates": "off"
    },
    "workspaces": [
      "app/shellplugin",
      "app/test",
      "app/usagedata",
      "app/systemstatus",
      "packages/ui5-reuse-tablestatus",
      "approuter"
    ]
  }
}
